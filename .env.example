# SafraCerta.ai - Environment Variables Template

PORT=3333

# Supabase Credentials (Cloud Auth & Database)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini AI (Agricultural Diagnostics)
GEMINI_API_KEY=your_gemini_api_key

# Satellite Monitoring Module
# Mapbox (https://mapbox.com — free tier 50k loads/month)
VITE_MAPBOX_TOKEN=

# Sentinel Hub (https://www.sentinel-hub.com — free tier available)
VITE_SENTINEL_INSTANCE_ID=
VITE_SENTINEL_CLIENT_ID=
VITE_SENTINEL_CLIENT_SECRET=
